{
  "name": "@mutour/opencode-channels",
  "version": "1.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mutour/opencode-channels.git"
  },
  "description": "Gateway application bridging Feishu/Lark with the OpenCode engine.",
  "main": "src/index.js",
  "bin": {
    "oc-channels": "src/index.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "setup": "node src/index.js setup",
    "start": "node src/index.js start",
    "stop": "node src/index.js stop",
    "restart": "node src/index.js restart",
    "dev": "node src/index.js start --log",
    "status": "node src/index.js status",
    "whitelist": "node src/index.js whitelist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:log": "node src/index.js start --log"
  },
  "keywords": [
    "opencode",
    "feishu",
    "lark",
    "bot",
    "ai",
    "gateway"
