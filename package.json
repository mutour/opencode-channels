  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "axios": "^1.13.6",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "eventsource": "^4.1.0",
    "https-proxy-agent": "^7.0.6",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  }
